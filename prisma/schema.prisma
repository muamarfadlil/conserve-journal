// prisma/schema.prisma

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

// ============================================================
// ENUM
// ============================================================

enum Role {
  SUPER_ADMIN
  ADMIN
  USER
}

// ============================================================
// AUTH MODELS
// ============================================================

model User {
  id        String   @id @default(cuid())
  name      String
  email     String   @unique
  password  String
  role      Role     @default(USER)
  isActive  Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

// ============================================================
// JOURNAL MODELS
// ============================================================

model Volume {
  id       Int       @id @default(autoincrement())
  number   Int
  issue    Int
  year     Int
  month    String?
  articles Article[]
}

model Article {
  id          Int       @id @default(autoincrement())
  title       String
  abstract    String    @db.Text
  doi         String?
  pdfUrl      String?
  pages       String?
  category    String?
  keywords    String[]
  publishedAt DateTime?

  volume   Volume @relation(fields: [volumeId], references: [id])
  volumeId Int

  authors Author[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Author {
  id          Int      @id @default(autoincrement())
  name        String
  affiliation String?
  email       String?

  articles Article[]
}
