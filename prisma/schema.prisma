// prisma/schema.prisma

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

// ============================================================
// ENUM
// ============================================================

enum Role {
  SUPER_ADMIN
  ADMIN
  REVIEWER
  USER
}

// ============================================================
// AUTH MODELS
// ============================================================

model User {
  id          String       @id @default(cuid())
  name        String
  email       String       @unique
  password    String
  role        Role         @default(USER)
  isActive    Boolean      @default(true)
  createdAt   DateTime     @default(now())
  updatedAt   DateTime     @updatedAt
  submissions        Submission[] @relation("SubmissionAuthor")
  reviewAssignments  Submission[] @relation("SubmissionReviewer")
}

// ============================================================
// JOURNAL MODELS
// ============================================================

model Volume {
  id       Int       @id @default(autoincrement())
  number   Int
  issue    Int
  year     Int
  month    String?
  articles Article[]
}

model Article {
  id          Int       @id @default(autoincrement())
  title       String
  abstract    String    @db.Text
  doi         String?
  pdfUrl      String?
  pages       String?
  category    String?
  keywords    String[]
  publishedAt DateTime?

  volume   Volume @relation(fields: [volumeId], references: [id])
  volumeId Int

  authors Author[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Author {
  id          Int      @id @default(autoincrement())
  name        String
  affiliation String?
  email       String?

  articles Article[]
}

// ============================================================
// SUBMISSION MODELS
// ============================================================

enum SubmissionStatus {
  DRAFT
  SUBMITTED
  UNDER_REVIEW
  REVISION
  ACCEPTED
  REJECTED
}

model Submission {
  id             Int              @id @default(autoincrement())
  title          String
  author         String
  affiliate      String
  correspondence String
  email          String
  abstract       String           @db.Text
  introduction   String           @db.Text
  methodology    String           @db.Text
  results        String           @db.Text
  conclusion     String           @db.Text
  references     String           @db.Text
  plagiasiUrl    String?
  coverLetterUrl String?
  attachmentUrls String[]         @default([])
  keywords       String[]         @default([])
  status         SubmissionStatus @default(DRAFT)
  comments         Json             @default("[]")
  reviewerNote     String?          @db.Text
  submittedById    String
  submittedBy      User             @relation("SubmissionAuthor", fields: [submittedById], references: [id])
  assignedReviewerId String?
  assignedReviewer   User?          @relation("SubmissionReviewer", fields: [assignedReviewerId], references: [id])
  createdAt      DateTime         @default(now())
  updatedAt      DateTime         @updatedAt
}

